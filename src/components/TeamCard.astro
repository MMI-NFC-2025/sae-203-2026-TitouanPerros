---
interface Props {
  name: string;
  role: string;
  imageSrc: string;
  imageAlt?: string;
}

const { name, role, imageSrc, imageAlt = name } = Astro.props;
---

<div class="flex items-center gap-4 rounded-2xl bg-white/5 px-5 py-4">
  <img
    src={imageSrc}
    alt={imageAlt}
    width="64"
    height="64"
    class="h-16 w-16 shrink-0 rounded-full object-cover shadow-md"
  />
  <div>
    <p class="font-bold text-white">{name}</p>
    <p class="text-sm text-gray-400">{role}</p>
  </div>
</div>
