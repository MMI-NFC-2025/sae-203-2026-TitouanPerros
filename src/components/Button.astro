---
const { href, text, variant = "default", classes, ariaLabel } = Astro.props;
const variantClass = {
  default: "bg-green text-dark",
  outlined: "text-white border border-white hover:inset-ring-8 hover:inset-ring-white",
  white: "bg-white text-green",
};

const currentVariant =
  (typeof variant === "string" && variant in variantClass ? variant : "default") as keyof typeof variantClass;
---

<a
  aria-label={ariaLabel}
  class:list={[
    "inline-flex w-fit items-center justify-center gap-4 whitespace-nowrap text-center px-6 py-4 text-xs font-bold tracking-wide transition duration-200 ease-in-out rounded-full lg:px-8 lg:py-6 lg:text-sm hover:scale-105 active:scale-95",
    variantClass[currentVariant],
    classes,
  ]}
  href={href}
>
  <slot />
  {text}
</a>
