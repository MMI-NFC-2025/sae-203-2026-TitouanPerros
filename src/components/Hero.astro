---
import { Image } from 'astro:assets';
import heroImg from '../assets/image/image3.avif';

interface Props {
  title: string;
  imageSrc?: string;
}

const { title, imageSrc = heroImg.src } = Astro.props;
---

<section class="relative flex min-h-[50vh] items-end px-6 pb-12">
  <div class="absolute inset-0 overflow-hidden">
    <Image src={heroImg} alt="concert" class="h-full w-full object-cover" />
  </div>

  <!-- Overlay sombre -->
  <div class="absolute inset-0 bg-black/60"></div>

  <!-- Titre centré -->
  <div class="relative z-10 w-full text-center">
    <h1 class="text-white">{title}</h1>
  </div>
</section>
