---
interface Props {
  question: string;
}
const { question } = Astro.props;
---

<details class="group border-b border-dark/10 last:border-b-0">
  <summary class="flex cursor-pointer items-center justify-between gap-4 py-4 text-normal-2 font-semibold text-dark select-none list-none">
    <span>{question}</span>
    <span class="shrink-0 text-green transition-transform duration-300 group-open:rotate-45">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
    </span>
  </summary>
  <div class="pb-4 text-petit leading-relaxed text-dark/70">
    <slot />
  </div>
</details>
