---
interface Props {
  question: string;
}
const { question } = Astro.props;
---

<details class="group rounded-2xl border border-dark/15 overflow-hidden">
  <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 text-petit font-medium text-green select-none list-none">
    <span>{question}</span>
    <span class="shrink-0 text-dark transition-transform duration-300 group-open:rotate-45">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
    </span>
  </summary>
  <div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-in-out group-open:grid-rows-[1fr]">
    <div class="overflow-hidden">
      <div class="px-6 pb-4 text-petit leading-relaxed text-dark/70">
        <slot />
      </div>
    </div>
  </div>
</details>
