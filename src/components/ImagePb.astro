---
import { getFileURL } from "../../backend/backend.mjs";
const { record, field, alt, classPicture, classImg, thumb } = Astro.props;
const imageUrl = record && field ? getFileURL(record, field, thumb) : null;
---

{
  imageUrl && (
    <picture class={classPicture}>
      <img src={imageUrl} class={classImg} alt={alt || ""} loading="lazy" decoding="async" />
    </picture>
  )
}
    />
  )
}