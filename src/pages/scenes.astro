---
import Layout from '../layouts/Layout.astro';
import CardScene from '../components/CardScene.astro';
import { getAllScenes, getAllArtists } from '../../backend/backend.mjs';
import parcImg from '../assets/image/parc 1.png';

const scenes = (await getAllScenes()) ?? [];
const allArtists = (await getAllArtists()) ?? [];

// Regroupement client-side : insensible à la casse et aux espaces
const normalize = (s: string) => s?.trim().toLowerCase() ?? '';

const scenesWithArtists = scenes.map((scene) => ({
  scene,
  artists: allArtists.filter(
    (a) => normalize(a.scene as string) === normalize(scene.nom as string)
  ),
}));
---

<Layout>
  <!-- ─── Hero ─── -->
  <section class="relative flex min-h-[40vh] flex-col items-center justify-center px-6 py-12 text-center">
    <div class="absolute inset-0 overflow-hidden">
      <img src={parcImg.src} alt="" loading="eager" decoding="async" class="h-full w-full object-cover" />
    </div>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative z-10">
      <h1 class="text-white">La Scène</h1>
    </div>
  </section>

  <!-- ─── Intro ─── -->
  <section class="bg-white px-6 py-10">
    <p class="text-normal-2 leading-relaxed text-dark/80">
      Les scènes du Flying TapFest vous offrira une atmosphère chaleureuse grâce à son cadre
      unique : le parc Le Pré La Rose. Vous y découvrirez des performances inoubliables
      portées par des artistes de renom.
    </p>
  </section>

  <!-- ─── Grille des scènes ─── -->
  <section class="bg-white pb-16 flex flex-col gap-10">
    <div class="flex flex-col gap-10 px-6 lg:grid lg:grid-cols-3 lg:gap-8 lg:max-w-5xl lg:mx-auto lg:w-full">
      {scenesWithArtists.map(({ scene, artists }) => (
        <CardScene
          record={scene}
          nom={scene.nom}
          description={scene.description}
          capacite={scene.capacite}
          photo={scene.photo}
          artists={artists}
        />
      ))}
    </div>

    {scenes.length === 0 && (
      <p class="px-6 text-petit text-dark/40">Aucune scène pour le moment.</p>
    )}
  </section>
</Layout>
